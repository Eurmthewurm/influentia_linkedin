# ─────────────────────────────────────────────────────────────────────────────
# .env — Your private configuration for Influentia.
# Fill in the values below, then save as .env (the installer does this for you).
# Never share or commit your .env file.
# ─────────────────────────────────────────────────────────────────────────────
# No API keys needed — AI and search are included in your Influentia subscription.
# ─────────────────────────────────────────────────────────────────────────────

# ── Your identity (used to personalise every message) ────────────────────────
YOUR_NAME=Your First Name
YOUR_COMPANY=Your Company
YOUR_GOAL=book a quick call
YOUR_GOAL_LINK=https://calendly.com/your-handle/discoverycall
YOUR_WEBSITE=https://www.yourcompany.com

# ── Reddit credentials (for posting comments via browser) ──────────────────
# Only REDDIT_USERNAME and REDDIT_PASSWORD are required.
# On first post a browser opens for you to log in — after that it's automatic.
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Optional OAuth credentials (if you have a Reddit API app):
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# ── Optional overrides ──────────────────────────────────────────────────────
# Comma-separated list of locations to skip when finding leads (optional)
EXCLUDED_LOCATIONS=

# Safety limits (do NOT raise these blindly — LinkedIn will flag the account)
MAX_CONNECTION_REQUESTS_PER_DAY=15
MAX_MESSAGES_PER_DAY=20
DELAY_BETWEEN_REQUESTS_SECONDS=60
POLL_INTERVAL_HOURS=4

# Follow-up behaviour
FOLLOW_UP_AFTER_DAYS=2
MAX_FOLLOW_UPS=2
