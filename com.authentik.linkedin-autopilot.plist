<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.authentik.linkedin-autopilot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ermoegberts/Desktop/linkedin_outreach/daily_autopilot.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/ermoegberts/Desktop/linkedin_outreach</string>

    <!-- Run every day at 9:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/ermoegberts/Desktop/linkedin_outreach/autopilot_run.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/ermoegberts/Desktop/linkedin_outreach/autopilot_run.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
